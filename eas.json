{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "image": "macos-sequoia-15.6-xcode-16.4"
      },
      "env": {
        "EXPO_PUBLIC_FIREBASE_ENABLED": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "image": "macos-sequoia-15.6-xcode-16.4"
      },
      "env": {
        "EXPO_PUBLIC_FIREBASE_ENABLED": "false"
      }
    },
    "preview-simulator": {
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "image": "macos-sequoia-15.6-xcode-16.4"
      },
      "env": {
        "EXPO_PUBLIC_FIREBASE_ENABLED": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "macos-sequoia-15.6-xcode-16.4"
      },
      "env": {
        "EXPO_PUBLIC_FIREBASE_ENABLED": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
